---
import Layout from "../../layouts/Layout.astro";
import SkillCard from "../../components/SkillCard.astro";
import { getCollection } from "astro:content";
import { withBase } from "../../lib/url";

export async function getStaticPaths() {
  const skills = await getCollection("skills");
  const tags = new Set<string>();
  for (const skill of skills) for (const t of skill.data.tags) tags.add(t);

  return [...tags].map((tag) => ({
    params: { tag },
    props: {
      tag,
      skills: skills
        .filter((s) => s.data.tags.includes(tag))
        .sort((a, b) => a.data.name.localeCompare(b.data.name)),
    },
  }));
}

const { tag, skills } = Astro.props;
---

<Layout
  title={`#${tag} skills`}
  description={`Copilot Studio skills tagged "${tag}".`}
>
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 sm:py-10">
    <a
      href={withBase("/")}
      class="inline-flex items-center gap-1.5 text-sm text-slate-400 hover:text-white transition-colors"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        class="h-4 w-4"
      >
        <path d="m15 18-6-6 6-6" stroke-linecap="round" stroke-linejoin="round"
        ></path>
      </svg>
      All skills
    </a>

    <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-white">
      <span class="text-brand-300">#</span>{tag}
    </h1>
    <p class="mt-1 text-slate-400">
      {skills.length}
      {skills.length === 1 ? "skill" : "skills"} tagged “{tag}”.
    </p>

    <div
      class="mt-7 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4"
    >
      {
        skills.map((skill) => (
          <SkillCard
            slug={skill.id}
            name={skill.data.name}
            description={skill.data.description}
            platforms={skill.data.platforms}
            tags={skill.data.tags}
            author={skill.data.author}
            coverColor={skill.data.coverColor}
            hasBundle={Boolean(skill.data.bundle)}
          />
        ))
      }
    </div>
  </div>
</Layout>
