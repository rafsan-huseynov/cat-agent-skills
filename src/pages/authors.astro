---
import Layout from "../layouts/Layout.astro";
import { withBase } from "../lib/url";
import { formatDate } from "../lib/skills";
import { allAuthors } from "../lib/badges";
import { loadBadgeSkills } from "../lib/badge-data";

// Build the public contribution ledger from the baked skills. Everything here is
// public (author, github login, featured, dates); the snarky badge is layered on
// client-side when a visitor looks up their own handle. The same loader feeds the
// poster page + OG image, so the directory and the shared posters never disagree.
const badgeSkills = await loadBadgeSkills();
const authors = allAuthors(badgeSkills);
const totalSkills = badgeSkills.length;
const featuredTotal = badgeSkills.filter((s) => s.featured).length;

// How many skill chips to show per author card before collapsing to "+N more".
const MAX_CHIPS = 8;
---

<Layout
  title="Contributors"
  description="Everyone who has shipped a skill to the CAT Agent Skills gallery — look up your handle to reveal your own personal contributor badge."
>
  <section class="mx-auto max-w-7xl px-4 py-10 sm:px-6">
    <header class="mb-8">
      <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">
        Contributors
      </h1>
      <p class="mt-2 max-w-2xl text-muted">
        Everyone who has shipped a skill to the gallery — each with a{" "}
        <strong class="text-fg">personal badge</strong> waiting to be claimed.
      </p>
      <p class="mt-1 text-sm text-muted">
        {authors.length} contributors · {totalSkills} skills · {featuredTotal} featured
      </p>
    </header>

    {/* ── The "You" panel: private snark, revealed client-side ── */}
    <section id="you-panel" class="you-panel mb-14">
      <div class="you-head">
        <div class="you-headings">
          <h2 class="you-title">Your contributor badge</h2>
          <p class="you-sub">
            Enter your GitHub handle to reveal the badge you’ve earned —
            computed live from your public contributions, and a little
            tongue-in-cheek.
          </p>
        </div>

        <div class="you-tools">
          <form id="you-form" class="you-field" role="search">
            <span class="you-at" aria-hidden="true">@</span>
            <input
              id="gh-login"
              type="text"
              autocomplete="username"
              spellcheck="false"
              placeholder="your-github-handle"
              aria-label="Your GitHub handle"
            />
            <button type="submit" class="you-submit">Show my badge</button>
          </form>
          <div id="you-saved" class="you-saved">
            <span class="you-who" id="you-who" />
            <button id="you-forget" type="button" class="you-remove">
              Remove handle
            </button>
          </div>
        </div>
      </div>

      <div id="you-result" class="hidden" aria-live="polite"></div>
    </section>

    {/* ── Public directory: neutral, no snark for others ── */}
    <div class="mb-4 flex items-baseline justify-between gap-3">
      <h2 class="text-lg font-semibold">All contributors</h2>
      <span class="hidden text-sm text-muted sm:inline">
        sorted by skills shipped
      </span>
    </div>
    <ul class="author-grid" role="list">
      {
        authors.map((a) => {
          const shown = a.skills.slice(0, MAX_CHIPS);
          const extra = a.skillCount - shown.length;
          return (
            <li class="author-card" data-login={a.login}>
              <div class="author-top">
                <img
                  src={`https://github.com/${a.login}.png?size=96`}
                  alt=""
                  width="44"
                  height="44"
                  loading="lazy"
                  class="author-avatar"
                />
                <div class="min-w-0 flex-1">
                  <div class="flex items-center gap-2">
                    <a
                      href={`https://github.com/${a.login}`}
                      target="_blank"
                      rel="noopener"
                      class="truncate font-medium hover:text-accent-text"
                    >
                      {a.displayName}
                    </a>
                    <span class="you-flag hidden">you</span>
                  </div>
                  <div class="truncate text-sm text-muted">@{a.login}</div>
                </div>
                <div class="author-count">
                  <span class="author-count-num">{a.skillCount}</span>
                  <span class="author-count-label">
                    skill{a.skillCount === 1 ? "" : "s"}
                  </span>
                </div>
              </div>

              <ul class="skill-chips" role="list">
                {shown.map((s) => (
                  <li>
                    <a class="chip" href={withBase(`/skills/${s.slug}`)} title={s.name}>
                      {s.featured && (
                        <svg
                          class="chip-star"
                          viewBox="0 0 24 24"
                          fill="currentColor"
                          aria-hidden="true"
                        >
                          <path d="M12 2.5l2.9 5.88 6.49.94-4.7 4.58 1.11 6.46L12 17.9l-5.8 3.05 1.11-6.46-4.7-4.58 6.49-.94L12 2.5z" />
                        </svg>
                      )}
                      <span class="chip-name">{s.name}</span>
                    </a>
                  </li>
                ))}
                {extra > 0 && <li class="chip-more">+{extra} more</li>}
              </ul>

              {(a.featuredCount > 0 || a.newestCreatedAtMs) && (
                <div class="author-foot">
                  {a.featuredCount > 0 && (
                    <span class="foot-item">
                      <svg class="chip-star" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M12 2.5l2.9 5.88 6.49.94-4.7 4.58 1.11 6.46L12 17.9l-5.8 3.05 1.11-6.46-4.7-4.58 6.49-.94L12 2.5z" />
                      </svg>
                      {a.featuredCount} featured
                    </span>
                  )}
                  {a.newestCreatedAtMs && (
                    <span class="foot-item">
                      latest {formatDate(new Date(a.newestCreatedAtMs))}
                    </span>
                  )}
                </div>
              )}
            </li>
          );
        })
      }
    </ul>
  </section>

  <style>
    /* ---- "You" panel + form (template elements → scoped) ---- */
    .you-panel {
      border: 1px solid var(--border);
      border-radius: 1.25rem;
      background: var(--surface);
      padding: 1.25rem;
    }
    @media (min-width: 640px) {
      .you-panel {
        padding: 1.5rem 1.75rem;
      }
    }
    .you-head {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .you-headings {
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
      max-width: 34rem;
    }
    .you-title {
      font-size: 1.25rem;
      font-weight: 650;
      letter-spacing: -0.01em;
      color: var(--fg);
    }
    .you-sub {
      font-size: 0.9rem;
      line-height: 1.5;
      color: var(--muted);
    }
    .you-tools {
      display: flex;
      flex-direction: column;
      align-items: stretch;
      gap: 0.6rem;
      flex: none;
    }
    @media (min-width: 720px) {
      .you-head {
        flex-direction: row;
        align-items: center;
        justify-content: space-between;
        gap: 2.5rem;
      }
      .you-tools {
        align-items: flex-end;
      }
    }
    .you-field {
      display: flex;
      align-items: center;
      gap: 0.3rem;
      width: 100%;
      max-width: 24rem;
      padding: 0.32rem 0.32rem 0.32rem 0.85rem;
      border: 1px solid var(--border);
      border-radius: 0.85rem;
      background: var(--bg);
      transition:
        border-color 0.15s,
        box-shadow 0.15s;
    }
    @media (min-width: 720px) {
      .you-field {
        width: 22rem;
      }
    }
    .you-field:focus-within {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 16%, transparent);
    }
    .you-at {
      color: var(--muted);
      font-size: 0.95rem;
      user-select: none;
    }
    .you-field input {
      flex: 1;
      min-width: 0;
      background: transparent;
      border: 0;
      outline: none;
      padding: 0.5rem 0.1rem;
      font-size: 0.95rem;
      color: var(--fg);
    }
    .you-submit {
      flex: none;
      border-radius: 0.62rem;
      background: var(--accent);
      color: var(--accent-fg);
      padding: 0.55rem 1.05rem;
      font-size: 0.875rem;
      font-weight: 600;
      white-space: nowrap;
      transition: opacity 0.15s;
    }
    .you-submit:hover {
      opacity: 0.9;
    }
    /* Remembered-handle chip (shown after a lookup; toggled via inline display
       so it beats the scoped [data-astro-cid] attribute selector). */
    .you-saved {
      display: none;
      align-items: center;
      gap: 0.6rem;
    }
    .you-who {
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--fg);
    }
    .you-remove {
      border-radius: 0.6rem;
      border: 1px solid var(--border);
      background: var(--surface-2);
      color: var(--muted);
      padding: 0.42rem 0.75rem;
      font-size: 0.8rem;
      font-weight: 500;
      transition:
        border-color 0.15s,
        color 0.15s;
    }
    .you-remove:hover {
      border-color: var(--accent);
      color: var(--fg);
    }

    /* ---- Directory grid + author cards (template elements → scoped) ---- */
    /* Even grid: every card in a row shares the tallest card's height so there
       are no ragged gaps between rows, while the left-to-right "sorted by
       skills shipped" order is preserved. Cards are flex columns so the footer
       pins to the bottom edge (see .author-foot). */
    .author-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.85rem;
      align-items: stretch;
    }
    @media (min-width: 640px) {
      .author-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    @media (min-width: 1120px) {
      .author-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }
    .author-card {
      display: flex;
      flex-direction: column;
      border: 1px solid var(--border);
      border-radius: 0.9rem;
      background: var(--surface);
      padding: 1rem;
      transition:
        border-color 0.15s,
        box-shadow 0.15s;
    }
    .author-card:hover {
      border-color: color-mix(in srgb, var(--accent) 35%, var(--border));
    }
    .author-card.is-you {
      border-color: var(--accent);
      box-shadow: 0 0 0 1px var(--accent);
    }
    .author-card.is-you .you-flag {
      display: inline-block;
    }
    .you-flag {
      flex-shrink: 0;
      border-radius: 999px;
      background: var(--accent);
      color: var(--accent-fg);
      padding: 0.05rem 0.5rem;
      font-size: 11px;
      font-weight: 600;
    }
    .author-top {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }
    .author-avatar {
      width: 2.75rem;
      height: 2.75rem;
      flex-shrink: 0;
      border-radius: 999px;
      background: var(--surface-2);
    }
    .author-count {
      flex-shrink: 0;
      text-align: center;
      line-height: 1;
    }
    .author-count-num {
      display: block;
      font-family: "JetBrains Mono", ui-monospace, monospace;
      font-weight: 700;
      font-size: 1.15rem;
      color: var(--fg);
    }
    .author-count-label {
      display: block;
      margin-top: 0.15rem;
      font-size: 0.68rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--subtle);
    }
    .skill-chips {
      display: flex;
      flex-wrap: wrap;
      gap: 0.375rem;
      margin-top: 0.85rem;
    }
    /* Keep breathing room above the pinned footer even when a card's content
       fills the (stretched) height, where the footer's auto top-margin is 0. */
    .skill-chips:has(+ .author-foot) {
      margin-bottom: 0.85rem;
    }
    .chip {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      max-width: 100%;
      padding: 0.2rem 0.55rem;
      border-radius: 999px;
      background: var(--surface-2);
      border: 1px solid transparent;
      font-size: 0.75rem;
      color: var(--fg);
      transition:
        border-color 0.15s,
        color 0.15s;
    }
    .chip:hover {
      border-color: color-mix(in srgb, var(--accent) 45%, transparent);
      color: var(--accent-text);
    }
    .chip-name {
      max-width: 12rem;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .chip-star {
      width: 0.7rem;
      height: 0.7rem;
      flex-shrink: 0;
      color: #e0a92e;
    }
    .chip-more {
      display: inline-flex;
      align-items: center;
      padding: 0.2rem 0.55rem;
      font-size: 0.75rem;
      color: var(--muted);
    }
    .author-foot {
      display: flex;
      flex-wrap: wrap;
      gap: 0.85rem;
      margin-top: auto;
      padding-top: 0.7rem;
      border-top: 1px solid var(--border);
      font-size: 0.75rem;
      color: var(--muted);
    }
    .foot-item {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
    }
  </style>

  {/* Award reveal is injected via innerHTML, so its styles must be GLOBAL
      (Astro scoped styles never reach dynamically-inserted nodes). Namespaced
      under #you-result so nothing leaks to the rest of the site. */}
  <style is:global>
    #you-result {
      margin-top: 1.5rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--border);
    }
    #you-result .award {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 2.75rem;
      align-items: center;
    }
    @media (max-width: 640px) {
      #you-result .award {
        grid-template-columns: 1fr;
        gap: 1.1rem;
        justify-items: center;
        text-align: center;
      }
      #you-result .award-badge {
        width: 200px;
      }
      #you-result .award-glow {
        width: 240px;
        height: 240px;
      }
      #you-result .award-title {
        font-size: 1.7rem;
      }
      #you-result .award-quote {
        font-size: 1.08rem;
        margin-inline: auto;
      }
      #you-result .award-stats {
        justify-content: center;
      }
    }
    #you-result .award-stage {
      position: relative;
      display: grid;
      place-items: center;
      padding: 0.5rem;
    }
    #you-result .award-glow {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 300px;
      height: 300px;
      border-radius: 999px;
      background: radial-gradient(circle, var(--glow) 0%, transparent 68%);
    }
    #you-result .award-badge {
      position: relative;
      width: 248px;
      height: auto;
      filter: drop-shadow(0 16px 26px rgb(0 0 0 / 0.24));
    }
    #you-result .award-eyebrow {
      font-family: "JetBrains Mono", ui-monospace, monospace;
      font-size: 0.6875rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--accent-text);
    }
    #you-result .award-title {
      margin-top: 0.5rem;
      font-size: 2.05rem;
      font-weight: 700;
      letter-spacing: -0.015em;
      line-height: 1.08;
      color: var(--fg);
    }
    #you-result .award-quote {
      margin-top: 0.7rem;
      max-width: 54ch;
      font-size: 1.2rem;
      font-style: italic;
      line-height: 1.5;
      color: var(--fg);
    }
    #you-result .award-stats {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 1.1rem;
    }
    #you-result .stat {
      min-width: 5.2rem;
      padding: 0.5rem 0.7rem;
      border: 1px solid var(--border);
      border-radius: 0.7rem;
      background: var(--surface-2);
    }
    #you-result .stat-num {
      display: block;
      font-family: "JetBrains Mono", ui-monospace, monospace;
      font-weight: 700;
      font-size: 1.2rem;
      line-height: 1;
      color: var(--fg);
    }
    #you-result .stat-label {
      display: block;
      margin-top: 0.3rem;
      font-family: "JetBrains Mono", ui-monospace, monospace;
      font-size: 0.625rem;
      letter-spacing: 0.09em;
      text-transform: uppercase;
      color: var(--muted);
    }
    #you-result .award-note {
      margin-top: 1.1rem;
      font-size: 0.75rem;
      color: var(--muted);
    }
    #you-result .award-download {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      margin-top: 1.15rem;
      padding: 0.5rem 0.95rem;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: var(--surface-2);
      color: var(--accent-text);
      font-size: 0.85rem;
      font-weight: 600;
      text-decoration: none;
      transition:
        border-color 0.15s ease,
        background 0.15s ease;
    }
    #you-result .award-download:hover {
      border-color: var(--accent);
      background: var(--accent-soft);
    }
    #you-result .award-download:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }
    #you-result .badge-empty {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      border: 1px dashed var(--border);
      border-radius: 0.85rem;
      background: var(--surface);
      padding: 1rem 1.15rem;
      color: var(--muted);
    }
    #you-result .badge-empty svg {
      width: 1.4rem;
      height: 1.4rem;
      flex-shrink: 0;
      color: var(--subtle);
    }
    @media (prefers-reduced-motion: no-preference) {
      #you-result .award-badge {
        animation: badgeIn 0.6s cubic-bezier(0.2, 0.7, 0.2, 1) both;
      }
      #you-result .award-glow {
        animation: glowIn 0.9s ease both;
      }
      #you-result .award-eyebrow {
        animation: riseIn 0.5s ease 0.05s both;
      }
      #you-result .award-title {
        animation: riseIn 0.5s ease 0.12s both;
      }
      #you-result .award-quote {
        animation: riseIn 0.5s ease 0.18s both;
      }
      #you-result .stat {
        animation: riseIn 0.5s ease both;
      }
      #you-result .stat:nth-child(1) {
        animation-delay: 0.24s;
      }
      #you-result .stat:nth-child(2) {
        animation-delay: 0.3s;
      }
      #you-result .stat:nth-child(3) {
        animation-delay: 0.36s;
      }
      #you-result .award-note {
        animation: riseIn 0.5s ease 0.42s both;
      }
      #you-result .award-download {
        animation: riseIn 0.5s ease 0.48s both;
      }
    }
    @keyframes badgeIn {
      from {
        opacity: 0;
        transform: translateY(10px) scale(0.92);
      }
      to {
        opacity: 1;
        transform: none;
      }
    }
    @keyframes riseIn {
      from {
        opacity: 0;
        transform: translateY(8px);
      }
      to {
        opacity: 1;
        transform: none;
      }
    }
    @keyframes glowIn {
      from {
        opacity: 0;
      }
      to {
        opacity: 1;
      }
    }
  </style>

  <script>
    import {
      computeStats,
      resolveBadge,
      captionFor,
      posterTiles,
      BADGES,
      type BadgeId,
    } from "../lib/badges";

    const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");
    const LS_KEY = "cat-badge-login";
    const png = (img: string) => `${BASE}/badges/${img}.png`;
    const svg = (img: string) => `${BASE}/badges/${img}.svg`;

    const form = document.getElementById("you-form") as HTMLFormElement | null;
    const input = document.getElementById("gh-login") as HTMLInputElement | null;
    const result = document.getElementById("you-result");
    const savedEl = document.getElementById("you-saved");
    const whoEl = document.getElementById("you-who");
    const forgetBtn = document.getElementById("you-forget");

    let data: any[] = [];
    async function loadData() {
      if (data.length) return data;
      const res = await fetch(`${BASE}/skills.json`);
      data = await res.json();
      return data;
    }

    function esc(s: string) {
      return s.replace(
        /[&<>"]/g,
        (c) =>
          ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" })[c] || c,
      );
    }

    function show(html: string) {
      if (!result) return;
      result.innerHTML = html;
      result.classList.remove("hidden");
      result.scrollIntoView({ behavior: "smooth", block: "nearest" });
    }

    function highlight(login: string) {
      document.querySelectorAll<HTMLElement>(".author-card").forEach((el) => {
        el.classList.toggle("is-you", el.dataset.login === login);
      });
    }

    function statTile(num: string, label: string) {
      return `<div class="stat"><span class="stat-num">${esc(
        num,
      )}</span><span class="stat-label">${esc(label)}</span></div>`;
    }

    // Evidence tiles come from the shared `posterTiles` helper so the on-site
    // reveal, the poster page, and the OG image always render identical stats.
    function tilesFor(badge: any, stats: any) {
      return posterTiles(badge, stats)
        .map((t) => statTile(t.num, t.label))
        .join("");
    }

    function cardHtml(login: string, stats: any, badge: any, caption: string) {
      const tiles = tilesFor(badge, stats);
      const real = login && login !== "preview";
      const who = real ? `Issued to @${esc(login)}` : "Badge preview";
      // Offer the one-click download only for real contributors (each has a
      // pre-rendered PNG). That image is the whole shareable artifact — caption,
      // stat tiles and site URL are all baked in — so posting it needs no page.
      const shareable = real && !!resolveBadge(login, data);
      const share = shareable
        ? `<a class="award-download" href="${BASE}/badge/${encodeURIComponent(
            login,
          )}.png" download="cat-badge-${login}.png"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3v12"/><path d="m8 11 4 4 4-4"/><path d="M5 21h14"/></svg>Download image</a>`
        : "";
      return `
        <div class="award">
          <div class="award-stage">
            <div class="award-glow" aria-hidden="true"></div>
            <img class="award-badge" src="${png(badge.image)}" alt="${esc(
              badge.title,
            )} badge" width="200" height="220"
                 onerror="this.onerror=null;this.src='${svg(badge.image)}'">
          </div>
          <div class="award-body">
            <p class="award-eyebrow">${who}</p>
            <h3 class="award-title">${esc(badge.title)}</h3>
            <p class="award-quote">&ldquo;${esc(caption)}&rdquo;</p>
            <div class="award-stats">${tiles}</div>
            <p class="award-note">${esc(badge.meaning || "")}</p>
            ${share}
          </div>
        </div>`;
    }

    function emptyHtml(login: string) {
      return `
        <div class="badge-empty">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.5l2.9 5.88 6.49.94-4.7 4.58 1.11 6.46L12 17.9l-5.8 3.05 1.11-6.46-4.7-4.58 6.49-.94L12 2.5z"/></svg>
          <p>No skills yet under <strong>@${esc(
            login,
          )}</strong> — no badge to show. Ship one and check back. 🐱</p>
        </div>`;
    }

    async function renderFor(
      login: string,
      forced?: BadgeId,
    ): Promise<boolean> {
      const norm = login.trim().replace(/^@/, "").toLowerCase();
      if (!norm && !forced) return false;
      await loadData();
      let stats = computeStats(norm, data);
      let badge: any;
      let caption: string;
      if (forced && (BADGES as any)[forced]) {
        badge = (BADGES as any)[forced];
        caption = captionFor(badge, norm || forced);
        // When a badge is forced via ?badge= but no live votes exist (e.g. a
        // shared preview link, or empty local ratings), seed a representative
        // count so the Crowd Favorite tile isn't blank.
        if (forced === "top-rated" && !stats.totalRating) {
          stats = { ...stats, totalRating: 128 };
        }
      } else {
        const r = resolveBadge(norm, data);
        if (!r) {
          show(emptyHtml(norm));
          highlight("");
          return false;
        }
        badge = r.badge;
        caption = r.caption;
      }
      if (input) input.value = norm;
      show(cardHtml(norm || "preview", stats, badge, caption));
      highlight(norm);
      return true;
    }

    // Remember the looked-up handle in this browser so the badge reappears on
    // return. Nothing leaves the device; "Remove handle" clears it. Inline
    // display beats the scoped rules (which carry Astro's [data-astro-cid]
    // attribute and would otherwise win over a class).
    function rememberHandle(login: string) {
      const norm = login.trim().replace(/^@/, "").toLowerCase();
      if (!norm) return;
      try {
        localStorage.setItem(LS_KEY, norm);
      } catch {}
      if (whoEl) whoEl.textContent = "@" + norm;
      if (savedEl) savedEl.style.display = "inline-flex";
      if (form) form.style.display = "none";
    }

    function forgetHandle() {
      try {
        localStorage.removeItem(LS_KEY);
      } catch {}
      if (savedEl) savedEl.style.display = "none";
      if (form) form.style.display = "";
      result?.classList.add("hidden");
      if (result) result.innerHTML = "";
      if (input) input.value = "";
      highlight("");
    }

    forgetBtn?.addEventListener("click", forgetHandle);

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!input) return;
      const ok = await renderFor(input.value);
      if (ok) rememberHandle(input.value);
    });

    // Init. ?as=<handle>&badge=<id> reveals a specific badge via a shareable
    // URL; otherwise a handle remembered in this browser auto-reveals (and is
    // dropped if it no longer maps to a badge).
    const params = new URLSearchParams(location.search);
    const asLogin = params.get("as");
    const forced = (params.get("badge") as BadgeId | null) || undefined;
    if (asLogin) {
      renderFor(asLogin, forced);
    } else if (forced) {
      renderFor("", forced);
    } else {
      let saved = "";
      try {
        saved = localStorage.getItem(LS_KEY) || "";
      } catch {}
      if (saved) {
        rememberHandle(saved);
        renderFor(saved).then((ok) => {
          if (!ok) forgetHandle();
        });
      }
    }
  </script>
</Layout>
