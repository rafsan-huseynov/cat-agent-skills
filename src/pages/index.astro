---
import Layout from "../layouts/Layout.astro";
import SkillCard from "../components/SkillCard.astro";
import { getCollection } from "astro:content";
import { PLATFORMS, PLATFORM_COLORS } from "../lib/skills";
import { getRating } from "../lib/ratings";

const isSample = (s: { data: { tags: string[] } }) =>
  s.data.tags.includes("sample");

const skills = (await getCollection("skills")).sort((a, b) => {
  if (isSample(a) !== isSample(b)) return isSample(a) ? 1 : -1;
  if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
  return a.data.name.localeCompare(b.data.name);
});

const platformCounts = new Map<string, number>();
for (const skill of skills) {
  for (const platform of skill.data.platforms) {
    platformCounts.set(platform, (platformCounts.get(platform) ?? 0) + 1);
  }
}

const tagCounts = new Map<string, number>();
for (const skill of skills) {
  for (const tag of skill.data.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  }
}
const allTags = [...tagCounts.entries()].sort(
  (a, b) => b[1] - a[1] || a[0].localeCompare(b[0])
);
// On mobile the full tag list pushes the gallery far down the page, so we show
// only the most-used tags and collapse the rest behind a disclosure. Desktop
// (>= sm) always shows them all.
const COLLAPSED_TAGS = 8;
const hiddenTagCount = Math.max(0, allTags.length - COLLAPSED_TAGS);
---

<Layout>
  <!-- Hero -->
  <section class="border-b border-border bg-surface/40">
    <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 sm:py-10">
      <h1
        class="text-2xl font-bold tracking-tight text-fg sm:text-3xl"
      >
        The gallery of skills for your AI agents
      </h1>
      <p class="mt-2 max-w-2xl text-muted">
        Browse <span class="text-fg">skills and plugins contributed by the
        community</span>: drop-in instructions and script bundles that teach your
        agents new tricks. Find one, download the markdown (and scripts), and add
        it to <span class="text-fg">Cowork</span>, <span
          class="text-fg">Copilot Studio</span
        >, or <span class="text-fg">Scout</span>.
      </p>

      <!-- Search -->
      <div class="mt-6 max-w-xl">
        <label for="skill-search" class="sr-only">Search skills</label>
        <div class="relative">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            class="pointer-events-none absolute left-4 top-1/2 h-5 w-5 -translate-y-1/2 text-subtle"
          >
            <circle cx="11" cy="11" r="7"></circle>
            <path d="m21 21-4.3-4.3" stroke-linecap="round"></path>
          </svg>
          <input
            id="skill-search"
            type="search"
            placeholder="Search skills by name, description, or tag…"
            autocomplete="off"
            class="w-full rounded-xl border border-border bg-surface py-2.5 pl-11 pr-4 text-fg placeholder:text-subtle outline-none transition focus:border-accent focus:ring-2 focus:ring-accent/25"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Platform filters -->
  <section class="border-b border-border bg-bg">
    <div
      class="mx-auto flex max-w-7xl flex-wrap items-center gap-3 px-4 py-4 sm:px-6"
    >
      <span class="text-xs font-semibold uppercase tracking-wider text-subtle"
        >Platform</span
      >
      <div id="platform-filters" class="flex flex-wrap gap-2">
        <button
          type="button"
          data-platform=""
          class="platform-chip rounded-full border border-accent bg-accent-soft px-3.5 py-1.5 text-sm font-semibold text-accent-text transition"
          aria-pressed="true">All platforms</button
        >
        {
          PLATFORMS.map((platform) => (
            <button
              type="button"
              data-platform={platform}
              class="platform-chip flex items-center gap-2 rounded-full border border-border bg-surface-2 px-3.5 py-1.5 text-sm font-semibold text-muted transition hover:border-accent/40 hover:text-fg"
              aria-pressed="false"
            >
              <span
                class="h-2 w-2 rounded-full"
                style={`background:${PLATFORM_COLORS[platform]}`}
              />
              {platform}
              <span class="text-xs text-subtle">
                {platformCounts.get(platform) ?? 0}
              </span>
            </button>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Tag filters -->
  <section class="border-b border-border bg-bg">
    <div class="mx-auto max-w-7xl px-4 py-4 sm:px-6">
      <div
        id="tag-filters"
        class="tags-collapsed flex flex-wrap items-center gap-2"
      >
        <button
          type="button"
          data-tag=""
          class="tag-chip rounded-full border border-accent bg-accent-soft px-3 py-1 text-sm font-medium text-accent-text transition"
          aria-pressed="true">All</button
        >
        {
          allTags.map(([tag, count], i) => (
            <button
              type="button"
              data-tag={tag}
              class:list={[
                "tag-chip rounded-full border border-border bg-surface-2 px-3 py-1 text-sm font-medium text-muted transition hover:border-accent/40 hover:text-fg",
                i >= COLLAPSED_TAGS && "tag-overflow",
              ]}
              aria-pressed="false"
            >
              {tag}
              <span class="ml-1 text-xs text-subtle">{count}</span>
            </button>
          ))
        }
        {
          hiddenTagCount > 0 && (
            <button
              type="button"
              id="tag-toggle"
              class="rounded-full border border-dashed border-border px-3 py-1 text-sm font-medium text-accent-text transition hover:border-accent/60 sm:hidden"
              aria-expanded="false"
              aria-controls="tag-filters"
            >
              +{hiddenTagCount} more
            </button>
          )
        }
      </div>
    </div>
  </section>

  <!-- Gallery -->
  <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 sm:py-10">
    <div class="mb-5 flex flex-wrap items-center justify-between gap-4">
      <h2 class="text-lg font-semibold text-fg">
        Skills <span id="result-count" class="text-muted"
          >({skills.length})</span
        >
      </h2>
      <div class="flex flex-wrap items-center gap-3">
        <div id="type-filters" class="flex flex-wrap gap-2">
          <button
            type="button"
            data-type=""
            class="type-chip rounded-full border border-accent bg-accent-soft px-3 py-1 text-sm font-medium text-accent-text transition"
            aria-pressed="true">All</button
          >
          <button
            type="button"
            data-type="skill"
            class="type-chip rounded-full border border-border bg-surface-2 px-3 py-1 text-sm font-medium text-muted transition hover:border-accent/40 hover:text-fg"
            aria-pressed="false">Skills</button
          >
          <button
            type="button"
            data-type="plugin"
            class="type-chip rounded-full border border-border bg-surface-2 px-3 py-1 text-sm font-medium text-muted transition hover:border-accent/40 hover:text-fg"
            aria-pressed="false">Plugins</button
          >
          <button
            type="button"
            data-type="automation"
            class="type-chip rounded-full border border-border bg-surface-2 px-3 py-1 text-sm font-medium text-muted transition hover:border-accent/40 hover:text-fg"
            aria-pressed="false">Automations</button
          >
        </div>
        <label class="flex items-center gap-2 text-sm text-muted">
          <span class="hidden sm:inline">Sort by</span>
          <select
            id="sort-select"
            class="rounded-lg border border-border bg-surface-2 px-3 py-1.5 text-sm text-fg focus:border-accent focus:outline-none"
          >
            <option value="featured">Featured</option>
            <option value="rating">Top rated</option>
            <option value="name">Name (A–Z)</option>
            <option value="newest">Newest</option>
          </select>
        </label>
      </div>
    </div>

    <div
      id="gallery"
      class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 2xl:grid-cols-5"
    >
      {
        skills.map((skill) => (
          <div
            class="skill-item"
            data-name={skill.data.name.toLowerCase()}
            data-desc={skill.data.description.toLowerCase()}
            data-tags={skill.data.tags.join(",").toLowerCase()}
            data-platforms={skill.data.platforms.join(",")}
            data-type={skill.data.type}
            data-rating={getRating(skill.id)}
            data-featured={skill.data.featured ? "1" : "0"}
            data-sample={skill.data.tags.includes("sample") ? "1" : "0"}
            data-updated={(
              skill.data.updatedAt ??
              skill.data.createdAt ??
              new Date(0)
            ).getTime()}
          >
            <SkillCard
              slug={skill.id}
              name={skill.data.name}
              description={skill.data.description}
              platforms={skill.data.platforms}
              type={skill.data.type}
              tags={skill.data.tags}
              author={skill.data.author}
              coverColor={skill.data.coverColor}
              hasBundle={Boolean(skill.data.bundle)}
              isInstaller={skill.data.type === "automation" && Boolean(skill.data.bundle?.endsWith(".zip"))}
              rating={getRating(skill.id)}
            />
          </div>
        ))
      }
    </div>

    <p id="empty-state" class="hidden py-16 text-center text-muted">
      No skills match your search. Try a different term or clear the filters.
    </p>

    <div id="scroll-sentinel" class="h-10"></div>
  </section>
</Layout>

<script>
  const BATCH = 12;

  const gallery = document.getElementById("gallery")!;
  const items = Array.from(
    gallery.querySelectorAll<HTMLElement>(".skill-item")
  );
  const search = document.getElementById("skill-search") as HTMLInputElement;
  const tagChips = Array.from(
    document.querySelectorAll<HTMLButtonElement>(".tag-chip")
  );
  const platformChips = Array.from(
    document.querySelectorAll<HTMLButtonElement>(".platform-chip")
  );
  const typeChips = Array.from(
    document.querySelectorAll<HTMLButtonElement>(".type-chip")
  );
  const countEl = document.getElementById("result-count")!;
  const emptyEl = document.getElementById("empty-state")!;
  const sentinel = document.getElementById("scroll-sentinel")!;
  const sortSelect = document.getElementById("sort-select") as HTMLSelectElement;

  const SORTS = ["featured", "rating", "name", "newest"] as const;
  type SortMode = (typeof SORTS)[number];

  let query = "";
  let activeTag = "";
  let activePlatform = "";
  let activeType = "";
  let sortMode: SortMode = "featured";
  let shown = BATCH;
  let matched: HTMLElement[] = items;

  const num = (el: HTMLElement, key: string) => Number(el.dataset[key] ?? "0") || 0;

  function computeMatched(): HTMLElement[] {
    return items.filter((el) => {
      const tags = (el.dataset.tags ?? "").split(",");
      const platforms = (el.dataset.platforms ?? "").split(",");
      const tagOk = !activeTag || tags.includes(activeTag);
      const platformOk = !activePlatform || platforms.includes(activePlatform);
      const typeOk = !activeType || (el.dataset.type ?? "skill") === activeType;
      const text = `${el.dataset.name} ${el.dataset.desc} ${el.dataset.tags}`;
      const queryOk = !query || text.includes(query);
      return tagOk && platformOk && typeOk && queryOk;
    });
  }

  function applySort(list: HTMLElement[]): HTMLElement[] {
    const byName = (a: HTMLElement, b: HTMLElement) =>
      (a.dataset.name ?? "").localeCompare(b.dataset.name ?? "");
    return [...list].sort((a, b) => {
      const sampleDiff = num(a, "sample") - num(b, "sample");
      if (sampleDiff !== 0) return sampleDiff;
      switch (sortMode) {
        case "rating":
          return num(b, "rating") - num(a, "rating") || byName(a, b);
        case "name":
          return byName(a, b);
        case "newest":
          return num(b, "updated") - num(a, "updated") || byName(a, b);
        case "featured":
        default:
          return num(b, "featured") - num(a, "featured") || byName(a, b);
      }
    });
  }

  function reorderDom() {
    const frag = document.createDocumentFragment();
    matched.forEach((el) => frag.appendChild(el));
    items.filter((el) => !matched.includes(el)).forEach((el) => frag.appendChild(el));
    gallery.appendChild(frag);
  }

  function render() {
    items.forEach((el) => (el.style.display = "none"));
    matched.slice(0, shown).forEach((el) => (el.style.display = ""));
    countEl.textContent = `(${matched.length})`;
    emptyEl.classList.toggle("hidden", matched.length > 0);
  }

  function refilter() {
    matched = applySort(computeMatched());
    shown = BATCH;
    reorderDom();
    render();
  }

  // Search (debounced)
  let t: number | undefined;
  search.addEventListener("input", () => {
    window.clearTimeout(t);
    t = window.setTimeout(() => {
      query = search.value.trim().toLowerCase();
      syncUrl();
      refilter();
    }, 120);
  });

  function paintChips(
    chips: HTMLButtonElement[],
    key: "tag" | "platform" | "type",
    active: string
  ) {
    chips.forEach((c) => {
      const on = (c.dataset[key] ?? "") === active;
      c.setAttribute("aria-pressed", String(on));
      c.classList.toggle("border-accent", on);
      c.classList.toggle("bg-accent-soft", on);
      c.classList.toggle("text-accent-text", on);
      c.classList.toggle("border-border", !on);
      c.classList.toggle("bg-surface-2", !on);
      c.classList.toggle("text-muted", !on);
    });
  }

  // Tag chips
  tagChips.forEach((chip) => {
    chip.addEventListener("click", () => {
      activeTag = chip.dataset.tag ?? "";
      paintChips(tagChips, "tag", activeTag);
      syncUrl();
      refilter();
    });
  });

  // Platform chips
  platformChips.forEach((chip) => {
    chip.addEventListener("click", () => {
      activePlatform = chip.dataset.platform ?? "";
      paintChips(platformChips, "platform", activePlatform);
      syncUrl();
      refilter();
    });
  });

  // Type chips (All / Skills / Plugins)
  typeChips.forEach((chip) => {
    chip.addEventListener("click", () => {
      activeType = chip.dataset.type ?? "";
      paintChips(typeChips, "type", activeType);
      syncUrl();
      refilter();
    });
  });

  // Sort dropdown
  sortSelect.addEventListener("change", () => {
    const v = sortSelect.value as SortMode;
    sortMode = SORTS.includes(v) ? v : "featured";
    syncUrl();
    refilter();
  });

  // Mobile tag disclosure: expand/collapse the overflow tags.
  const tagFilters = document.getElementById("tag-filters")!;
  const tagToggle = document.getElementById("tag-toggle");
  function setTagsExpanded(expanded: boolean) {
    tagFilters.classList.toggle("tags-collapsed", !expanded);
    if (tagToggle) {
      tagToggle.setAttribute("aria-expanded", String(expanded));
      tagToggle.textContent = expanded
        ? "Show fewer"
        : `+${tagFilters.querySelectorAll(".tag-overflow").length} more`;
    }
  }
  tagToggle?.addEventListener("click", () =>
    setTagsExpanded(tagFilters.classList.contains("tags-collapsed"))
  );
  const io = new IntersectionObserver(
    (entries) => {
      if (entries[0].isIntersecting && shown < matched.length) {
        shown = Math.min(shown + BATCH, matched.length);
        render();
      }
    },
    { rootMargin: "400px" }
  );
  io.observe(sentinel);

  // URL state (?q=&tag=&platform=&sort=) for shareable filters.
  function syncUrl() {
    const params = new URLSearchParams();
    if (query) params.set("q", query);
    if (activeTag) params.set("tag", activeTag);
    if (activePlatform) params.set("platform", activePlatform);
    if (activeType) params.set("type", activeType);
    if (sortMode !== "featured") params.set("sort", sortMode);
    const qs = params.toString();
    history.replaceState(null, "", qs ? `?${qs}` : location.pathname);
  }

  function initFromUrl() {
    const params = new URLSearchParams(location.search);
    query = (params.get("q") ?? "").toLowerCase();
    activeTag = params.get("tag") ?? "";
    activePlatform = params.get("platform") ?? "";
    activeType = params.get("type") ?? "";
    const s = params.get("sort") as SortMode | null;
    sortMode = s && SORTS.includes(s) ? s : "featured";
    sortSelect.value = sortMode;
    search.value = query;
    paintChips(tagChips, "tag", activeTag);
    paintChips(platformChips, "platform", activePlatform);
    paintChips(typeChips, "type", activeType);
    // If a filtered-on tag is hidden in the collapsed overflow, reveal it.
    if (
      activeTag &&
      tagFilters
        .querySelector<HTMLButtonElement>(`.tag-chip[data-tag="${CSS.escape(activeTag)}"]`)
        ?.classList.contains("tag-overflow")
    ) {
      setTagsExpanded(true);
    }
    refilter();
  }

  initFromUrl();

  // Restore from the back/forward cache (bfcache) does not re-run this module,
  // so filter state, the visible-count, and the infinite-scroll batch can be
  // left frozen out of sync with the DOM. Reconcile on persisted pageshow.
  window.addEventListener("pageshow", (event) => {
    if (event.persisted) initFromUrl();
  });
</script>

<style>
  /* Only collapse the tag list on mobile; sm+ always shows every tag. */
  @media (max-width: 639px) {
    #tag-filters.tags-collapsed .tag-overflow {
      display: none;
    }
  }
</style>
