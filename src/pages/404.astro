---
import Layout from "../layouts/Layout.astro";
import { withBase } from "../lib/url";
---

<Layout title="Page not found">
  <div
    class="mx-auto flex max-w-2xl flex-col items-center px-4 py-24 text-center sm:px-6"
  >
    <p class="text-7xl font-black text-brand-500">404</p>
    <h1 class="mt-4 text-2xl font-bold text-white">This page wandered off</h1>
    <p class="mt-2 text-slate-400">
      The skill or page you’re looking for doesn’t exist (or moved).
    </p>
    <a
      href={withBase("/")}
      class="mt-6 rounded-lg bg-brand-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-brand-500 transition-colors"
      >Back to the gallery</a
    >
  </div>
</Layout>
